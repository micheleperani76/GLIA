#!/usr/bin/env bash
# ============================================================
#  mypc - AI terminal assistant (Ollama + aichat)
#  Version: 1.2 - 2026-07-11
#  Author: Michele (with Claude)
#  Project: GLIA (GNU Linux IA)
#
#  What's new in v1.2:
#   - model read from config: ~/.config/glia/model, then /etc/glia/model
#     (written by the installer), then built-in default
#  What's new in v1.1:
#   - startup self-check: starts Ollama if stopped, tells you
#     exactly what to do if the model is missing
#   - --rename <name>: rename the assistant to whatever you want
#   - help and messages use the current command name
#
#  Usage:
#    mypc <request>        propose a command (Enter = run)
#    mypc -d <question>    plain-text answer, no command
#    mypc -l               show the command log
#    mypc --rename <name>  rename the assistant
#    mypc -h               this help
# ============================================================

# ----------------- CONFIGURATION -----------------
# Model selection (first match wins):
#   1. ~/.config/glia/model   (per-user choice)
#   2. /etc/glia/model        (system default, written by the installer)
#   3. DEFAULT_MODEL below
DEFAULT_MODEL="qwen2.5-coder:7b"
if [ -r "$HOME/.config/glia/model" ]; then
    MODEL="ollama:$(head -n1 "$HOME/.config/glia/model")"
elif [ -r /etc/glia/model ]; then
    MODEL="ollama:$(head -n1 /etc/glia/model)"
else
    MODEL="ollama:$DEFAULT_MODEL"
fi
PROG="$(basename "$0")"
LOGDIR="$HOME/.local/share/$PROG"
LOGFILE="$LOGDIR/$PROG.log"
OLLAMA_URL="http://localhost:11434"

# Patterns that require extra confirmation (they don't block: they ask to type YES)
# Extended regexes, one per line: add/remove freely
EXTRA_CONFIRM_PATTERNS=(
    'rm .*-[a-zA-Z]*[rf]'
    '\bdd\b'
    '\bmkfs'
    '\bshred\b'
    '\bwipefs\b'
    '>\s*/dev/(sd|nvme|mmcblk)'
    'chmod .*(777|-R)'
    'chown .*-R'
    '\bparted\b|\bfdisk\b|\bcfdisk\b|\bsgdisk\b'
    '\btruncate\b'
    '\bmv\b.*/dev/null'
    ':\(\)\s*\{'
    '\b(curl|wget)\b.*\|\s*(ba|z|da)?sh'
    '\bsudo\b'
)

# Context given to the model to generate correct commands
# (OS name and user are detected at runtime, so the same script works
#  on the installed system and on the GLIA live ISO)
OS_NAME=$(. /etc/os-release 2>/dev/null && echo "${PRETTY_NAME:-Linux}")
CONTEXT="System: ${OS_NAME:-Linux}, user: $USER. \
Commands will be executed with bash. Reply ONLY with a single-line bash \
command, no explanations, no markdown, no backticks."
# ---------------------------------------------------

# ------------------- FUNCTIONS ----------------------
RED='\033[1;31m'; GREEN='\033[1;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

show_help() {
    cat <<EOF
$PROG v1.2 - AI terminal assistant (model: ${MODEL#ollama:})

Usage:
  $PROG <request>        propose a shell command
                         Enter = run | n = cancel | r = retry
  $PROG -d <question>    plain-text answer, no command
  $PROG -l               show the command log
  $PROG --rename <name>  rename the assistant (example: $PROG --rename jarvis)
  $PROG -h               this help

Potentially destructive commands require typing YES.
Log: $LOGFILE

If the AI does not answer:
  systemctl start ollama          start the AI engine
  ollama pull ${MODEL#ollama:}    download the model
  glia-hardware                   see which model fits this machine
EOF
}

write_log() {
    # $1 = status, $2 = command
    mkdir -p "$LOGDIR"
    printf '%s | %s | %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$1" "$2" >> "$LOGFILE"
}

check_ai() {
    # make sure Ollama is running and the model is downloaded
    if ! curl -fsS --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
        echo -e "${YELLOW}Ollama is not running, starting it...${NC}" >&2
        systemctl start ollama 2>/dev/null || sudo systemctl start ollama 2>/dev/null
        local i
        for i in 1 2 3 4 5; do
            sleep 1
            curl -fsS --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1 && break
        done
    fi
    if ! curl -fsS --max-time 2 "$OLLAMA_URL/api/tags" >/dev/null 2>&1; then
        echo -e "${RED}Ollama is not running and could not be started.${NC}" >&2
        echo -e "Check it with:  systemctl status ollama" >&2
        exit 1
    fi
    if ! curl -fsS --max-time 5 "$OLLAMA_URL/api/tags" 2>/dev/null | grep -q "\"${MODEL#ollama:}\""; then
        echo -e "${YELLOW}The model ${MODEL#ollama:} is not downloaded yet.${NC}" >&2
        echo -e "Download it with:  ${GREEN}ollama pull ${MODEL#ollama:}${NC}" >&2
        echo -e "(or run glia-hardware to see which model fits this machine)" >&2
        exit 1
    fi
}

rename_assistant() {
    local newname="$1" self dest
    if [ -z "$newname" ]; then
        echo "Usage: $PROG --rename <newname>" >&2; exit 1
    fi
    if ! grep -qE '^[a-zA-Z][a-zA-Z0-9_-]*$' <<< "$newname"; then
        echo "Invalid name '$newname' (use letters, numbers, - or _; must start with a letter)." >&2
        exit 1
    fi
    self="$(realpath "$0")"
    dest="$(dirname "$self")/$newname"
    if [ -e "$dest" ]; then
        echo "A command named '$newname' already exists in $(dirname "$self")." >&2
        exit 1
    fi
    if mv "$self" "$dest" 2>/dev/null; then
        echo -e "${GREEN}Done. Your assistant is now called: $newname${NC}"
        echo "Try:  $newname -h"
    else
        echo -e "${RED}Permission denied. Try:  sudo $PROG --rename $newname${NC}" >&2
        exit 1
    fi
}

needs_extra_confirm() {
    # returns 0 if the command matches a sensitive pattern
    local cmd="$1" p
    for p in "${EXTRA_CONFIRM_PATTERNS[@]}"; do
        if grep -qiE "$p" <<< "$cmd"; then
            return 0
        fi
    done
    return 1
}

generate_command() {
    # asks the model for a command and cleans the output
    aichat --model "$MODEL" "$CONTEXT Request: $*" < /dev/null 2>/dev/null \
        | sed 's/^```[a-z]*//; s/```$//' \
        | grep -v '^\s*$' \
        | head -n 1
}

run_command() {
    local cmd="$1"
    bash -c "$cmd"
    local status=$?
    write_log "EXECUTED (exit=$status)" "$cmd"
    return $status
}

propose_and_run() {
    local request="$*" cmd answer
    while true; do
        echo -e "${YELLOW}Thinking...${NC}" >&2
        cmd=$(generate_command "$request")
        if [ -z "$cmd" ]; then
            echo -e "${RED}No command generated (the model gave an empty answer). Try again.${NC}" >&2
            exit 1
        fi
        echo
        echo -e "Proposed command:  ${GREEN}$cmd${NC}"
        if needs_extra_confirm "$cmd"; then
            echo -e "${RED}⚠ WARNING: potentially destructive command.${NC}"
            read -r -p "Type YES (uppercase) to run, r to retry, anything else to cancel: " answer < /dev/tty \
                || { write_log "CANCELLED (no tty)" "$cmd"; echo "Cancelled."; return; }
            case "$answer" in
                YES) run_command "$cmd"; return ;;
                r|R) continue ;;
                *)   write_log "CANCELLED" "$cmd"; echo "Cancelled."; return ;;
            esac
        else
            read -r -p "Enter = run | n = cancel | r = retry: " answer < /dev/tty \
                || { write_log "CANCELLED (no tty)" "$cmd"; echo "Cancelled."; return; }
            case "$answer" in
                "")  run_command "$cmd"; return ;;
                r|R) continue ;;
                *)   write_log "CANCELLED" "$cmd"; echo "Cancelled."; return ;;
            esac
        fi
    done
}

# --------------------- MAIN ------------------------
case "$1" in
    -h|--help|"")
        show_help
        ;;
    --rename)
        shift
        rename_assistant "$1"
        ;;
    -d)
        shift
        check_ai
        exec aichat --model "$MODEL" "$@"
        ;;
    -l)
        if [ -f "$LOGFILE" ]; then
            cat "$LOGFILE"
        else
            echo "No log yet ($LOGFILE)."
        fi
        ;;
    *)
        check_ai
        propose_and_run "$@"
        ;;
esac
