#!/usr/bin/env bash
# ============================================================
#  glia-firstboot - First-boot wizard for GLIA
#  Version: 1.0 - 2026-07-12
#  Author: Michele (with Claude)
#  Project: GLIA (GNU Linux IA)
#
#  Runs once at the first interactive login on the installed
#  system (triggered by /etc/profile.d/glia-firstboot.sh):
#   1. asks what to call the AI assistant (default: mypc)
#   2. makes sure the chosen AI model is available
# ============================================================

DONE_FLAG="/etc/glia/.firstboot-done"
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

# never on the live ISO, never twice
[ -d /run/archiso ] && exit 0
[ -f "$DONE_FLAG" ] && exit 0

SUDO=""
if [ "$EUID" -ne 0 ]; then
    SUDO="sudo"
    echo -e "${YELLOW}Welcome to GLIA! One-time setup (you may be asked for your password).${NC}"
else
    echo -e "${YELLOW}Welcome to GLIA! One-time setup.${NC}"
fi

# ---------- 1. assistant name ----------
CURRENT="mypc"
[ -x /usr/local/bin/mypc ] || CURRENT="$(basename "$(ls /usr/local/bin/ 2>/dev/null | head -n1)")"
echo
read -r -p "What do you want to call your AI assistant? [${CURRENT}] " NAME < /dev/tty
NAME="${NAME:-$CURRENT}"

if [ "$NAME" != "$CURRENT" ]; then
    if grep -qE '^[a-zA-Z][a-zA-Z0-9_-]*$' <<< "$NAME"; then
        if $SUDO "/usr/local/bin/$CURRENT" --rename "$NAME"; then
            CURRENT="$NAME"
        fi
    else
        echo "Invalid name, keeping '$CURRENT' (rename later with: $CURRENT --rename <name>)."
    fi
fi

# ---------- 2. model check ----------
MODEL="$(head -n1 /etc/glia/model 2>/dev/null)"
if [ -n "$MODEL" ] && ! ollama list 2>/dev/null | grep -q "$MODEL"; then
    echo
    echo -e "${YELLOW}The model you chose ($MODEL) is not on disk yet.${NC}"
    read -r -p "Download it now? Needs network. [Y/n] " A < /dev/tty
    case "$A" in
        n|N) echo "You can download it later with:  ollama pull $MODEL" ;;
        *)   ollama pull "$MODEL" || echo "Download failed - retry later with: ollama pull $MODEL" ;;
    esac
fi

$SUDO mkdir -p /etc/glia
$SUDO touch "$DONE_FLAG"
echo
echo -e "${GREEN}All set! Ask your assistant anything, e.g.:  $CURRENT show disk usage${NC}"
