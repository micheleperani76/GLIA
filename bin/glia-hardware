#!/usr/bin/env bash
# ============================================================
#  glia-hardware - Hardware detection and AI model recommendation
#  Version: 1.1 - 2026-07-14
#  Author: Michele (with Claude)
#  Project: GLIA / LinuxIA
#
#  Detects RAM and GPU and recommends the right Ollama model tier.
#  Used: manually, by the installer, and to switch AI engine.
#
#  What's new in v1.1 ("feasible list"):
#   - CATALOG: curated model catalog with per-model requirements
#     (min RAM/VRAM, download size, category)
#   - `-l`: prints up to 10 models FEASIBLE on this machine, best first,
#     machine-readable (name|download_gb|category|recommended) - used by
#     `glia -m pull` for the guided download menu
#   - CPU tier split: with >=24 GB RAM the recommended model is the MoE
#     qwen3:30b-a3b (3B active params: fast on CPU, big-model quality)
#   - JSON output gains "gpu_name"
#
#  Usage:
#    glia-hardware          full report with recommended models
#    glia-hardware -m       print only the recommended model (for scripts)
#    glia-hardware -l       feasible models for this machine (for glia -m pull)
#    glia-hardware -j       JSON output (for installer/Calamares)
#    glia-hardware -h       this help
# ============================================================

# ----------------- CONFIGURATION -----------------
# Models per tier: the first of each list is the recommended one
TIER1_MODELS=("qwen3:4b" "gemma3:4b" "llama3.2:3b")                 # base (<16 GB RAM, no GPU)
TIER2_MODELS=("qwen2.5-coder:7b" "qwen3:8b" "mistral:7b")           # mid  (>=16 GB RAM, no GPU)
TIER2PLUS_MODELS=("qwen3:30b-a3b" "qwen3:14b" "qwen2.5-coder:14b")  # mid+ (>=24 GB RAM, no GPU: MoE fits)
TIER3_MODELS=("qwen2.5-coder:14b" "phi4:14b" "deepseek-r1:14b")     # high (GPU >=12 GB VRAM)
TIER4_MODELS=("qwen3-coder:30b" "qwen2.5-coder:32b" "devstral:24b") # top  (GPU >=20 GB VRAM)

# Model catalog for the feasible list (-l), ordered best/biggest first.
#   name | min RAM (or VRAM) GB to run it | download GB | category
#   category: general | coding | light | moe | reasoning
CATALOG=(
    "qwen2.5-coder:32b|24|20|coding"
    "deepseek-r1:32b|24|20|reasoning"
    "qwen3-coder:30b|22|19|coding"
    "qwen3:30b-a3b|22|19|moe"
    "devstral:24b|18|14|coding"
    "qwen3:14b|11|9.3|general"
    "phi4:14b|11|9.1|general"
    "qwen2.5-coder:14b|11|9.0|coding"
    "deepseek-r1:14b|11|9.0|reasoning"
    "gemma3:12b|10|8.1|general"
    "qwen3:8b|6|5.2|general"
    "deepseek-r1:8b|6|5.2|reasoning"
    "llama3.1:8b|6|4.9|general"
    "qwen2.5-coder:7b|6|4.7|coding"
    "mistral:7b|5|4.1|general"
    "gemma3:4b|4|3.3|light"
    "qwen3:4b|4|2.6|light"
    "llama3.2:3b|3|2.0|light"
    "qwen3:1.7b|2|1.4|light"
)
# ---------------------------------------------------

# ------------------- FUNCTIONS ----------------------
GREEN='\033[1;32m'; YELLOW='\033[1;33m'; BLUE='\033[1;34m'; NC='\033[0m'

show_help() {
    cat <<EOF
glia-hardware v1.1 - detects hardware and recommends the AI model for glia

Usage:
  glia-hardware       full report
  glia-hardware -m    recommended model only
  glia-hardware -l    feasible models for this machine (name|download_gb|category|recommended)
  glia-hardware -j    JSON output
  glia-hardware -h    this help
EOF
}

detect_ram_gb() {
    awk '/MemTotal/ {printf "%.0f", $2/1024/1024}' /proc/meminfo
}

detect_gpu() {
    # sets: GPU_TYPE (nvidia|amd|intel|none) and GPU_VRAM_GB (0 if unknown)
    GPU_TYPE="none"; GPU_VRAM_GB=0; GPU_NAME="no dedicated GPU"
    local line
    line=$(lspci 2>/dev/null | grep -Ei 'vga|3d controller' | head -n 5)

    if grep -qi nvidia <<< "$line"; then
        GPU_TYPE="nvidia"
        GPU_NAME=$(grep -i nvidia <<< "$line" | head -n1 | cut -d: -f3- | sed 's/^ //')
        if command -v nvidia-smi >/dev/null 2>&1; then
            GPU_VRAM_GB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null \
                          | head -n1 | awk '{printf "%.0f", $1/1024}')
        fi
    elif grep -qi 'amd\|radeon' <<< "$line" && ! grep -qi 'raphael\|rembrandt\|phoenix\|granite ridge' <<< "$line"; then
        GPU_TYPE="amd"
        GPU_NAME=$(grep -Ei 'amd|radeon' <<< "$line" | head -n1 | cut -d: -f3- | sed 's/^ //')
        # AMD VRAM: first drm device with dedicated memory
        local f
        for f in /sys/class/drm/card*/device/mem_info_vram_total; do
            [ -r "$f" ] && GPU_VRAM_GB=$(awk '{printf "%.0f", $1/1024/1024/1024}' "$f") && break
        done
    elif grep -qi intel <<< "$line"; then
        GPU_TYPE="intel"
        GPU_NAME=$(grep -i intel <<< "$line" | head -n1 | cut -d: -f3- | sed 's/^ //')
    fi
    [ -z "$GPU_VRAM_GB" ] && GPU_VRAM_GB=0
}

pick_tier() {
    # sets TIER (1-4), MODELS[] and REASON
    if [ "$GPU_VRAM_GB" -ge 20 ]; then
        TIER=4; MODELS=("${TIER4_MODELS[@]}")
        REASON="$GPU_TYPE GPU with ${GPU_VRAM_GB} GB VRAM"
    elif [ "$GPU_VRAM_GB" -ge 12 ]; then
        TIER=3; MODELS=("${TIER3_MODELS[@]}")
        REASON="$GPU_TYPE GPU with ${GPU_VRAM_GB} GB VRAM"
    elif [ "$RAM_GB" -ge 24 ]; then
        TIER=2; MODELS=("${TIER2PLUS_MODELS[@]}")
        REASON="${RAM_GB} GB RAM, CPU inference (MoE fits)"
    elif [ "$RAM_GB" -ge 16 ]; then
        TIER=2; MODELS=("${TIER2_MODELS[@]}")
        REASON="${RAM_GB} GB RAM, CPU inference"
    else
        TIER=1; MODELS=("${TIER1_MODELS[@]}")
        REASON="${RAM_GB} GB RAM, CPU inference"
    fi
    RECOMMENDED="${MODELS[0]}"
}

report() {
    echo -e "${BLUE}=== GLIA - hardware detection ===${NC}"
    echo -e "CPU:    $(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | sed 's/^ //') ($(nproc) threads)"
    echo -e "RAM:    ${RAM_GB} GB"
    echo -e "GPU:    ${GPU_NAME}$( [ "$GPU_VRAM_GB" -gt 0 ] && echo " (${GPU_VRAM_GB} GB VRAM)" )"
    echo
    echo -e "Recommended tier: ${YELLOW}${TIER}${NC} (${REASON})"
    echo -e "Suitable models:"
    local m
    for m in "${MODELS[@]}"; do
        if [ "$m" = "$RECOMMENDED" ]; then
            echo -e "  ${GREEN}* $m   <- recommended${NC}"
        else
            echo -e "    $m"
        fi
    done
    echo
    echo "To install:  ollama pull $RECOMMENDED"
}

list_feasible() {
    # prints up to 10 models FEASIBLE on this machine, best first, as:
    #   name|download_gb|category|recommended(0/1)
    # feasible = fits in RAM (or in GPU VRAM) AND the download fits on disk.
    # Machine-readable on purpose: `glia -m pull` builds its menu from this.
    local dir avail_gb entry name min_ram dl cat need rec_line="" lines=""
    for dir in /usr/share/ollama /var/lib/ollama "$HOME/.ollama" "$HOME"; do
        [ -d "$dir" ] && break
    done
    avail_gb=$(df -BG --output=avail "$dir" 2>/dev/null | tail -n1 | tr -dc '0-9')
    for entry in "${CATALOG[@]}"; do
        IFS='|' read -r name min_ram dl cat <<< "$entry"
        # enough memory? (plain RAM, or dedicated GPU VRAM)
        if [ "$min_ram" -le "$RAM_GB" ] || { [ "$GPU_VRAM_GB" -gt 0 ] && [ "$min_ram" -le "$GPU_VRAM_GB" ]; }; then
            need=$(( ${dl%%.*} + 1 ))          # download size rounded up
            [ -n "$avail_gb" ] && [ "$need" -gt "$avail_gb" ] && continue
            if [ "$name" = "$RECOMMENDED" ]; then
                rec_line="$name|$dl|$cat|1"
            else
                lines+="$name|$dl|$cat|0"$'\n'
            fi
        fi
    done
    printf '%s\n%s' "$rec_line" "$lines" | sed '/^$/d' | head -n 10
}

output_json() {
    local list m first=1
    for m in "${MODELS[@]}"; do
        [ $first -eq 0 ] && list+=","
        list+="\"$m\""; first=0
    done
    cat <<EOF
{"ram_gb":$RAM_GB,"gpu_type":"$GPU_TYPE","gpu_name":"$GPU_NAME","gpu_vram_gb":$GPU_VRAM_GB,"tier":$TIER,"recommended":"$RECOMMENDED","models":[$list]}
EOF
}

# --------------------- MAIN ------------------------
RAM_GB=$(detect_ram_gb)
detect_gpu
pick_tier

case "$1" in
    -h|--help) show_help ;;
    -m)        echo "$RECOMMENDED" ;;
    -l)        list_feasible ;;
    -j)        output_json ;;
    "")        report ;;
    *)         show_help; exit 1 ;;
esac
