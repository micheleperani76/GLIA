#!/usr/bin/env bash
# ============================================================
#  glia-install - Launch the GLIA installer (Calamares)
#  Version: 1.1 - 2026-07-12 (layout tastiera it per la sessione cage)
#  Author: Michele (with Claude)
#  Project: GLIA (GNU Linux IA)
#
#  Runs Calamares fullscreen inside a minimal Wayland session
#  (cage), keeping the live environment terminal-first.
#
#  Usage:
#    glia-install
# ============================================================

set -e

if [ "$EUID" -ne 0 ]; then
    echo "Please run as root:  sudo glia-install" >&2
    exit 1
fi

if ! command -v calamares >/dev/null 2>&1; then
    echo "Calamares is not installed on this system." >&2
    exit 1
fi

# Minimal Wayland runtime for the kiosk session
export XDG_RUNTIME_DIR="/run/user/$EUID"
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"
export QT_QPA_PLATFORM=wayland
# Italian layout for the live session: Calamares' keyboard page can't
# change the compositor layout under Wayland (setxkbmap is X11-only)
export XKB_DEFAULT_LAYOUT=it
export XKB_DEFAULT_MODEL=pc105

echo "Starting the GLIA installer..."
exec cage -s -- calamares
